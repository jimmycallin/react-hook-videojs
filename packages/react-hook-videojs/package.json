{
  "name": "react-hook-videojs",
  "type": "module",
  "version": "0.0.0",
  "description": "A simple react hook to easily integrate video.js with React",
  "keywords": [
    "react",
    "react-hook",
    "video.js",
    "videojs",
    "player",
    "media"
  ],
  "author": "jimmycallin",
  "license": "MIT",
  "repository": "jimmycallin/react-hook-videojs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-hook-videojs.es.js"
    }
  },
  "source": "src/index.tsx",
  "engineStrict": false,
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "clean": "rimraf dist .tmp",
    "build": "vite build && tsc --project tsconfig.types.json",
    "test": "pnpm --workspace-root run test:unit",
    "prepare": "pnpm run clean && pnpm run build",
    "prepublishOnly": "pnpm --workspace-root run test",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "react": ">=19 < 20",
    "react-dom": ">=19 < 20",
    "video.js": ">=7 <9"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/video.js": "^7.3.51",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "video.js": "^8.23.7",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}

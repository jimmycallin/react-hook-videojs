{
  "name": "react-hook-videojs",
  "version": "3.0.2",
  "description": "A simple react hook to easily integrate video.js with React",
  "author": "jimmycallin",
  "license": "MIT",
  "repository": "jimmycallin/react-hook-videojs",
  "types": "./dist/index.d.ts",
  "main": "dist/react-hook-videojs.umd.js",
  "module": "dist/react-hook-videojs.es.js",
  "source": "src/index.tsx",
  "engineStrict": false,
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "clean": "rimraf dist .tmp",
    "build": "vite build && tsc --project tsconfig.types.json",
    "test": "pnpm --workspace-root run test:unit",
    "prepare": "pnpm run clean && pnpm run build",
    "prepublishOnly": "pnpm --workspace-root run test",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "react": ">=16.8.0 < 19",
    "react-dom": ">=16.8.0 < 19",
    "video.js": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/lodash.clonedeep": "^4.5.7",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/video.js": "^7.3.51",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "video.js": "^7.3.51",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "dequal": "^2.0.3",
    "lodash.clonedeep": "^4.5.0"
  }
}
